{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-agent.local/contracts/apps/runtime-event-v1.schema.json",
  "title": "Hermes App Runtime Event v1",
  "description": "JSON payload carried by each App Runtime SSE event.",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "run_id", "seq", "timestamp", "type", "payload"],
  "properties": {
    "protocol_version": {
      "const": 1
    },
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "seq": {
      "type": "integer",
      "minimum": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "type": {
      "type": "string",
      "enum": [
        "run.accepted",
        "run.started",
        "status",
        "text.delta",
        "data.snapshot",
        "data.delta",
        "operation.started",
        "operation.progress",
        "operation.completed",
        "usage.updated",
        "run.completed",
        "run.failed",
        "run.cancelled",
        "heartbeat"
      ]
    },
    "payload": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "run.accepted"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/runAccepted"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "run.started"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/runStarted"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "status"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/status"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "text.delta"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/textDelta"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "data.snapshot"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/dataSnapshot"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "data.delta"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/dataDelta"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "operation.started"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/operationStarted"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "operation.progress"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/operationProgress"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "operation.completed"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/operationCompleted"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "usage.updated"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/usage"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "run.completed"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/runCompleted"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "run.failed"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/runFailed"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "run.cancelled"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/runCancelled"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "heartbeat"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/heartbeat"
          }
        }
      }
    }
  ],
  "$defs": {
    "runAccepted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "queue_position"],
      "properties": {
        "action_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._-]{0,63}$"
        },
        "queue_position": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "runStarted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempt"],
      "properties": {
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        }
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "message"],
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["queued", "preparing", "running", "finalizing"]
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "progress": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "textDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 65536
        }
      }
    },
    "dataSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data"],
      "properties": {
        "data": true
      }
    },
    "jsonPatchOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "path"],
      "properties": {
        "op": {
          "type": "string",
          "enum": ["add", "remove", "replace"]
        },
        "path": {
          "type": "string",
          "pattern": "^(/([^~/]|~0|~1)*)*$",
          "maxLength": 1024
        },
        "value": true
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "op": {
                "enum": ["add", "replace"]
              }
            },
            "required": ["op"]
          },
          "then": {
            "required": ["value"]
          },
          "else": {
            "not": {
              "required": ["value"]
            }
          }
        }
      ]
    },
    "dataDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["patch"],
      "properties": {
        "patch": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/jsonPatchOperation"
          }
        }
      }
    },
    "operationStarted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "kind", "label"],
      "properties": {
        "operation_id": {
          "type": "string",
          "format": "uuid"
        },
        "kind": {
          "type": "string",
          "enum": ["agent", "mcp", "service"]
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        }
      }
    },
    "operationProgress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "progress"],
      "properties": {
        "operation_id": {
          "type": "string",
          "format": "uuid"
        },
        "progress": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "operationCompleted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id"],
      "properties": {
        "operation_id": {
          "type": "string",
          "format": "uuid"
        },
        "summary": {
          "type": "string",
          "maxLength": 500
        },
        "data": true
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "total_tokens"],
      "properties": {
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_cost_usd": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "runCompleted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result"],
      "properties": {
        "result": true,
        "usage": {
          "$ref": "#/$defs/usage"
        }
      }
    },
    "runFailed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error"],
      "properties": {
        "error": {
          "$ref": "#/$defs/error"
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]{2,63}$"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": "object"
        }
      }
    },
    "runCancelled": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "requested_by"],
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "requested_by": {
          "type": "string",
          "enum": ["app", "user", "runtime"]
        }
      }
    },
    "heartbeat": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 0
    }
  }
}
