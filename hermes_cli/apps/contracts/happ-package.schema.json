{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-agent.local/contracts/apps/happ-package-v1.schema.json",
  "title": "Hermes App Package Metadata v1",
  "description": "Schemas for happ.json, checksums.json, and optional signature.json in a .happ archive. Archive-level rules are frozen in happ-format-v1.md.",
  "$ref": "#/$defs/envelope",
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(-[0-9A-Za-z-]+(\\.[0-9A-Za-z-]+)*)?(\\+[0-9A-Za-z-]+(\\.[0-9A-Za-z-]+)*)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "archivePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^[^/\\\\][^\\\\]*$"
    },
    "envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format_version",
        "app_id",
        "app_version",
        "created_at",
        "created_by",
        "source_included",
        "manifest",
        "checksums"
      ],
      "properties": {
        "format_version": {
          "const": 1
        },
        "app_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*){2,}$",
          "maxLength": 128
        },
        "app_version": {
          "$ref": "#/$defs/semver"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "type": "string",
          "enum": ["hermes-desktop", "hermes-cli"]
        },
        "source_included": {
          "type": "boolean"
        },
        "manifest": {
          "const": "app.yaml"
        },
        "checksums": {
          "const": "checksums.json"
        },
        "signature": {
          "const": "signature.json"
        }
      }
    },
    "checksumEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "size", "sha256"],
      "properties": {
        "path": {
          "$ref": "#/$defs/archivePath"
        },
        "size": {
          "type": "integer",
          "minimum": 0,
          "maximum": 52428800
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "checksumManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format_version", "algorithm", "files"],
      "properties": {
        "format_version": {
          "const": 1
        },
        "algorithm": {
          "const": "sha256"
        },
        "files": {
          "type": "array",
          "minItems": 3,
          "maxItems": 4999,
          "items": {
            "$ref": "#/$defs/checksumEntry"
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format_version",
        "algorithm",
        "key_id",
        "signed_file",
        "signature"
      ],
      "properties": {
        "format_version": {
          "const": 1
        },
        "algorithm": {
          "const": "ed25519"
        },
        "key_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "signed_file": {
          "const": "checksums.json"
        },
        "signature": {
          "type": "string",
          "contentEncoding": "base64",
          "minLength": 86,
          "maxLength": 88
        }
      }
    }
  }
}
