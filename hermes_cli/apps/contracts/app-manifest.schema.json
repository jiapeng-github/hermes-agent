{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-agent.local/contracts/apps/app-manifest-v1.schema.json",
  "title": "Hermes App Manifest v1",
  "description": "Authoritative structural contract for local Hermes web applications. Trust and granted permissions are runtime-owned and cannot be declared here.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "version",
    "description",
    "entry",
    "icon",
    "sdk_version",
    "min_runtime_version",
    "permissions",
    "actions"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 5,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*){2,}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "version": {
      "$ref": "#/$defs/semver"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "entry": {
      "type": "string",
      "pattern": "^dist/[A-Za-z0-9._/-]+\\.html$",
      "maxLength": 512
    },
    "icon": {
      "type": "string",
      "pattern": "^(icon\\.(png|webp|jpg|jpeg)|assets/[A-Za-z0-9._/-]+\\.(png|webp|jpg|jpeg))$",
      "maxLength": 512
    },
    "source": {
      "type": "string",
      "pattern": "^source(/[A-Za-z0-9._/-]+)?$",
      "maxLength": 512
    },
    "sdk_version": {
      "$ref": "#/$defs/semver"
    },
    "min_runtime_version": {
      "$ref": "#/$defs/semver"
    },
    "display": {
      "$ref": "#/$defs/display"
    },
    "permissions": {
      "$ref": "#/$defs/permissions"
    },
    "actions": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 64,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9._-]{0,63}$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/action"
      }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(-[0-9A-Za-z-]+(\\.[0-9A-Za-z-]+)*)?(\\+[0-9A-Za-z-]+(\\.[0-9A-Za-z-]+)*)?$"
    },
    "relativeJsonPath": {
      "type": "string",
      "pattern": "^schemas/[A-Za-z0-9._/-]+\\.json$",
      "maxLength": 512
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "theme": {
          "type": "string",
          "enum": ["auto", "light", "dark"],
          "default": "auto"
        },
        "preferred_width": {
          "type": "integer",
          "minimum": 640,
          "maximum": 3840
        },
        "preferred_height": {
          "type": "integer",
          "minimum": 480,
          "maximum": 2160
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent", "mcp_servers", "storage"],
      "properties": {
        "agent": {
          "type": "boolean"
        },
        "mcp_servers": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          }
        },
        "storage": {
          "$ref": "#/$defs/storagePermission"
        }
      }
    },
    "storagePermission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "quota_mb"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["none", "session", "persistent"]
        },
        "quota_mb": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "none"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "properties": {
              "quota_mb": {
                "const": 0
              }
            }
          },
          "else": {
            "properties": {
              "quota_mb": {
                "minimum": 1
              }
            }
          }
        }
      ]
    },
    "actionBase": {
      "type": "object",
      "required": ["kind", "title", "input_schema", "output_schema"],
      "properties": {
        "kind": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "input_schema": {
          "$ref": "#/$defs/relativeJsonPath"
        },
        "output_schema": {
          "$ref": "#/$defs/relativeJsonPath"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 5,
          "maximum": 300,
          "default": 60
        },
        "max_concurrent_runs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4,
          "default": 1
        },
        "cache_ttl_seconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 86400,
          "default": 0
        }
      }
    },
    "agentAction": {
      "allOf": [
        {
          "$ref": "#/$defs/actionBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "title",
            "prompt",
            "input_schema",
            "output_schema",
            "mode",
            "toolsets",
            "timeout_seconds",
            "max_iterations",
            "max_concurrent_runs",
            "cache_ttl_seconds"
          ],
          "properties": {
            "kind": {
              "const": "agent"
            },
            "title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            },
            "prompt": {
              "type": "string",
              "pattern": "^prompts/[A-Za-z0-9._/-]+\\.md$",
              "maxLength": 512
            },
            "input_schema": {
              "$ref": "#/$defs/relativeJsonPath"
            },
            "output_schema": {
              "$ref": "#/$defs/relativeJsonPath"
            },
            "mode": {
              "type": "string",
              "enum": ["stateless", "conversation"]
            },
            "toolsets": {
              "type": "array",
              "maxItems": 16,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
              }
            },
            "timeout_seconds": {
              "type": "integer",
              "minimum": 5,
              "maximum": 300
            },
            "max_iterations": {
              "type": "integer",
              "minimum": 1,
              "maximum": 30
            },
            "max_concurrent_runs": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4
            },
            "cache_ttl_seconds": {
              "type": "integer",
              "minimum": 0,
              "maximum": 86400
            }
          }
        }
      ]
    },
    "mcpAction": {
      "allOf": [
        {
          "$ref": "#/$defs/actionBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "title",
            "server",
            "tool",
            "arguments_template",
            "input_schema",
            "output_schema",
            "timeout_seconds",
            "max_concurrent_runs",
            "cache_ttl_seconds"
          ],
          "properties": {
            "kind": {
              "const": "mcp"
            },
            "title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            },
            "server": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
            },
            "tool": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$"
            },
            "arguments_template": {
              "type": "object"
            },
            "input_schema": {
              "$ref": "#/$defs/relativeJsonPath"
            },
            "output_schema": {
              "$ref": "#/$defs/relativeJsonPath"
            },
            "timeout_seconds": {
              "type": "integer",
              "minimum": 5,
              "maximum": 300
            },
            "max_concurrent_runs": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4
            },
            "cache_ttl_seconds": {
              "type": "integer",
              "minimum": 0,
              "maximum": 86400
            }
          }
        }
      ]
    },
    "serviceAction": {
      "allOf": [
        {
          "$ref": "#/$defs/actionBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "description": "Reserved for runtime-owned built-in applications. User manifests cannot grant or establish built-in lineage.",
          "required": [
            "kind",
            "title",
            "handler",
            "input_schema",
            "output_schema",
            "timeout_seconds",
            "max_concurrent_runs",
            "cache_ttl_seconds"
          ],
          "properties": {
            "kind": {
              "const": "service"
            },
            "title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            },
            "handler": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[a-z][a-z0-9._-]*$"
            },
            "input_schema": {
              "$ref": "#/$defs/relativeJsonPath"
            },
            "output_schema": {
              "$ref": "#/$defs/relativeJsonPath"
            },
            "timeout_seconds": {
              "type": "integer",
              "minimum": 5,
              "maximum": 300
            },
            "max_concurrent_runs": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4
            },
            "cache_ttl_seconds": {
              "type": "integer",
              "minimum": 0,
              "maximum": 86400
            }
          }
        }
      ]
    },
    "action": {
      "oneOf": [
        {
          "$ref": "#/$defs/agentAction"
        },
        {
          "$ref": "#/$defs/mcpAction"
        },
        {
          "$ref": "#/$defs/serviceAction"
        }
      ]
    }
  }
}
